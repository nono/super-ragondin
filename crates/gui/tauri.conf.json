{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Super Ragondin",
  "version": "0.1.0",
  "identifier": "io.cozy.super-ragondin",
  "build": {
    "frontendDist": "../../gui-frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../../gui-frontend && npm run dev",
    "beforeBuildCommand": "cd ../../gui-frontend && npm run build"
  },
  "app": {
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "windows": [
      {
        "title": "Super Ragondin",
        "width": 420,
        "height": 320,
        "resizable": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
