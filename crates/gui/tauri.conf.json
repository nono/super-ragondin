{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Super Ragondin",
  "version": "0.1.0",
  "identifier": "io.cozy.super-ragondin",
  "build": {
    "frontendDist": "../../gui-frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../../gui-frontend && npm run dev",
    "beforeBuildCommand": "cd ../../gui-frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Super Ragondin",
        "width": 760,
        "height": 520,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/256x256.png",
        "icons/icon.ico",
        "icons/icon.png"
      ]
  }
}
